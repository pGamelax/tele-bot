// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  password      String?  // Senha hasheada (usado pelo Better Auth com emailAndPassword)
  emailVerified Boolean  @default(false)
  image         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accounts Account[]
  sessions Session[]
  bots     Bot[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  accountId         String
  userId            String
  providerId        String
  type              String  @default("credential")
  provider          String  @default("credential")
  providerAccountId String  @default(uuid())
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  password          String? @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @default(cuid())
  token        String   @unique
  userId       String
  expires      DateTime?
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Bot {
  id              String   @id @default(cuid())
  name            String
  telegramToken   String   @unique
  syncpayApiKey   String
  syncpayApiSecret String
  startImage      String?  // URL da imagem
  startCaption    String?  // Caption da imagem
  startButtonMessage String? @db.Text // Mensagem separada para os botões (se não houver, usa botões na caption)
  isActive        Boolean  @default(true)
  // Configuração de reenvio
  resendImage     String?  // URL da imagem para reenvio (mantido para compatibilidade)
  resendCaption   String?  // Caption para reenvio
  resendButtonMessage String? @db.Text // Mensagem separada para os botões de reenvio (se não houver, usa botões na caption)
  resendFirstDelay Int     @default(20) // Minutos até primeiro reenvio
  resendInterval  Int      @default(10) // Minutos entre reenvios
  // Rastreamento Facebook Ads
  facebookPixelId String?  // Facebook Pixel ID para rastreamento
  facebookAccessToken String?  // Facebook Access Token para Conversions API
  // Mensagem após confirmação de pagamento
  paymentConfirmedMessage String?  // Mensagem enviada após confirmação de pagamento
  // Upsell - oferta adicional após compra
  upsellImage      String?  // URL da imagem ou vídeo do upsell
  upsellMessage    String?  @db.Text // Mensagem de upsell enviada após confirmação
  upsellButtonText String?  // Texto do botão de upsell (ex: "Quero aproveitar!")
  upsellButtonValue Int?    // Valor em centavos do produto de upsell
  // Recuperação de PIX - lembrete para quem gerou e não pagou
  pixRecoveryEnabled Boolean @default(true)
  pixRecoveryMessage String?  @db.Text // Mensagem de lembrete (use {amount} e {pixCode})
  pixRecoveryDelayMinutes Int @default(10) // Minutos após gerar PIX para enviar lembrete
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  paymentButtons PaymentButton[]
  resendImages   ResendImage[]
  resendCaptions ResendCaption[]
  resendButtonGroups ResendButtonGroup[]
  leads          Lead[]
  payments       Payment[]

  @@map("bots")
}

model ResendImage {
  id          String   @id @default(cuid())
  botId       String
  imageUrl    String   // URL da imagem/vídeo
  order       Int      @default(0) // Ordem de exibição
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("resend_images")
  @@index([botId, order])
}

model ResendCaption {
  id          String   @id @default(cuid())
  botId       String
  captionText String   @db.Text // Texto da legenda
  order       Int      @default(0) // Ordem de exibição
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("resend_captions")
  @@index([botId, order])
}

model ResendButtonGroup {
  id          String   @id @default(cuid())
  botId       String
  buttons     String   @db.Text // JSON array de botões: [{"text": "Comprar", "value": 1290}, ...]
  order       Int      @default(0) // Ordem de exibição
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("resend_button_groups")
  @@index([botId, order])
}

model PaymentButton {
  id          String   @id @default(cuid())
  text        String   // Texto do botão
  value       Int      // Valor em centavos (ex: 1290 = R$ 12,90)
  type        String   @default("start") // "start" ou "resend"
  botId       String
  bot         Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("payment_buttons")
}

model Payment {
  id              String   @id @default(cuid())
  botId           String
  bot             Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  telegramChatId  String
  amount          Int      // Valor em centavos
  syncpayId       String?  // ID do pagamento no SyncPay
  status          String   @default("pending") // pending, paid, expired, cancelled
  pixCode         String?  // Código PIX
  qrCode          String?  // QR Code
  expiresAt       DateTime?
  paidAt          DateTime?
  pixRecoverySentAt  DateTime? // Quando foi enviado o lembrete de recuperação (1º)
  pixRecovery2SentAt DateTime? // Quando foi enviado o 2º lembrete de recuperação (~30 min)
  resendResumedAt    DateTime? // Quando o reenvio foi retomado (após 20 min sem pagar)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("payments")
}

model Lead {
  id              String   @id @default(cuid())
  botId           String
  telegramChatId  String
  telegramUsername String?
  firstName       String?
  lastName        String?
  isNew           Boolean  @default(true) // Marca se é um novo cliente
  notes           String?  // Notas sobre o lead
  contactedAt     DateTime? // Quando foi contatado
  convertedAt     DateTime? // Quando se tornou cliente (comprou)
  resendPaused    Boolean  @default(false) // Se o reenvio está pausado manualmente
  resendImageIndex Int     @default(0) // Índice da imagem atual para rotação
  resendCaptionIndex Int   @default(0) // Índice do texto atual para rotação
  resendButtonIndex Int    @default(0) // Índice do grupo de botões atual para rotação
  isBlocked       Boolean  @default(false) // Se o usuário bloqueou o bot
  // Rastreamento Facebook Ads / UTM
  utmSource       String?  // utm_source (ex: facebook, google)
  utmMedium       String?  // utm_medium (ex: cpc, social)
  utmCampaign     String?  // utm_campaign (nome da campanha)
  utmContent      String?  // utm_content (conteúdo específico)
  utmTerm         String?  // utm_term (palavra-chave)
  fbclid          String?  // Facebook Click ID
  gclid           String?  // Google Click ID
  ref             String?  // Parâmetro de referência customizado
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bot Bot @relation(fields: [botId], references: [id], onDelete: Cascade)

  @@map("leads")
}

